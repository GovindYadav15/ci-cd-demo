pipeline {
    agent any

    environment {
        IMAGE_NAME = 'robert803556/ci-cd-test'
        TAG = 'latest'
    }

    stages {
        stage('Pull Image') {
            steps {
                sh 'docker pull ${IMAGE_NAME}:${TAG}'
            }
        }

        stage('Deploy STAGE') {
            steps {
                sh '''
                    docker rm -f ci-cd-demo-stage || true
                    docker run -d --name ci-cd-demo-stage -p 4174:3000 ${IMAGE_NAME}:${TAG}
                '''
            }
        }

        stage('Health Check') {
            steps {
                sh '''
                    for i in 1 2 3 4 5; do
                        docker exec ci-cd-demo-stage node -e 'const http=require("http"); http.get("http://127.0.0.1:3000", res=>{ if (res.statusCode===200) process.exit(0); process.exit(1); }).on("error", ()=>process.exit(1));' && exit 0
                        echo "Waiting for app to become ready..."
                        sleep 3
                    done
                    echo "Container logs:"
                    docker logs ci-cd-demo-stage
                    exit 1
                '''
            }
        }
    }
}